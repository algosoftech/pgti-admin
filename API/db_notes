Cart Table Structure (Updated for Guest Users)
CREATE TABLE IF NOT EXISTS `cart` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `user_id` int(11) DEFAULT NULL,
  `guest_session_id` varchar(255) DEFAULT NULL,
  `product_id` int(11) NOT NULL,
  `variant_id` int(11) NOT NULL,
  `quantity` int(11) NOT NULL DEFAULT 1,
  `created_at` datetime DEFAULT NULL,
  `updated_at` datetime DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `user_id` (`user_id`),
  KEY `guest_session_id` (`guest_session_id`),
  KEY `product_id` (`product_id`),
  KEY `variant_id` (`variant_id`),
  UNIQUE KEY `unique_user_product_variant` (`user_id`, `product_id`, `variant_id`),
  UNIQUE KEY `unique_guest_product_variant` (`guest_session_id`, `product_id`, `variant_id`),
  CONSTRAINT `cart_ibfk_1` FOREIGN KEY (`user_id`) REFERENCES `users` (`id`) ON DELETE CASCADE,
  CONSTRAINT `cart_ibfk_2` FOREIGN KEY (`product_id`) REFERENCES `products` (`id`) ON DELETE CASCADE,
  CONSTRAINT `cart_ibfk_3` FOREIGN KEY (`variant_id`) REFERENCES `products_variants` (`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

-- Note: Either user_id OR guest_session_id should be set, not both
-- For authenticated users: user_id is set, guest_session_id is NULL
-- For guest users: user_id is NULL, guest_session_id is set
