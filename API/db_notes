CREATE OR REPLACE VIEW order_view AS
SELECT
    o.id,
    o.order_no,
    o.user_id,
    o.address_id,
    o.promo_code_id,
    o.subtotal,
    o.total,
    o.payment_method,
    o.payment_status,
    o.order_status,
    o.created_at,
    
    u.name AS user_name,
    u.phone AS user_phone,
    u.email AS user_email,
    
    ua.type AS address_type,
    ua.house,
    ua.floor,
    ua.locality,
    ua.area,
    ua.status AS address_status,

    IFNULL(
        JSON_ARRAYAGG(
            JSON_OBJECT(
                'id', oi.id,
                'order_id', oi.order_id,
                'product_id', oi.product_id,
                'variant_id', oi.variant_id,
                'quantity', oi.quantity,
                'rate', oi.rate,
                'discount_type', oi.discount_type,
                'discount', oi.discount,
                'discount_amount', oi.discount_amount,
                'subtotal', oi.subtotal,
                'total', oi.total,
                'status', oi.status,
                'created_at', oi.created_at
            )
        ),
        JSON_ARRAY()
    ) AS items

FROM
    orders o
LEFT JOIN order_items oi ON o.id = oi.order_id
LEFT JOIN users u ON o.user_id = u.id
LEFT JOIN users_address ua ON o.address_id = ua.id
GROUP BY o.id
ORDER BY o.created_at DESC;
