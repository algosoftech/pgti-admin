CREATE OR REPLACE VIEW products_with_variants AS
SELECT
    p.id AS id,
    p.image AS image,
    p.title AS title,
    p.description AS description,
    p.category AS category,
    p.subCategory AS subCategory,
    p.slug AS slug,
    p.made_two_order AS made_two_order,
    p.subscription_products AS subscription_products,
    p.fresh_item AS fresh_item,
    p.status AS status,
    p.created_at AS created_at,
    p.updated_at AS updated_at,

    IFNULL(
        JSON_ARRAYAGG(
            JSON_OBJECT(
                'id', v.id,
                'unit', v.unit,
                'rate', v.rate,
                'package_type', v.package_type,
                'expire_date', v.expire_date,
                'discount_type', v.discount_type,
                'discount_text', v.discount_text,
                'discount', v.discount,
                'total_stock', v.total_stock,
                'available_stock', v.available_stock,
                'status', v.status
            )
        ),
        JSON_ARRAY()
    ) AS variant

FROM
    products p
LEFT JOIN 
    products_variants v ON v.product = p.id
GROUP BY
    p.id;

////////////////
notes : 
SELECT *
FROM products_with_variants
WHERE JSON_CONTAINS(variants, JSON_OBJECT("status", "active"));
