CREATE OR REPLACE VIEW category_with_subcategories AS
SELECT 
    c.id AS category_id,
    c.image AS image,
    c.name AS category_name,
    c.status AS status,
    GROUP_CONCAT(s.name ORDER BY s.name SEPARATOR ', ') AS sub_categories
FROM 
    categories c
LEFT JOIN 
    sub_categories s ON s.category = c.id
GROUP BY 
    c.id, c.name;
