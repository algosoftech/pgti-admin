# -----------------------------------------------------------------------------
# PGTI Admin - Environment Variables
# Copy this file to .env and fill in the values for your environment.
# -----------------------------------------------------------------------------

# Backend API base URL (include /v1 suffix). Must end with a slash.
# Local development:
REACT_APP_API_BASE_URL=http://localhost:3301/v1/
# Production (uncomment):
# REACT_APP_API_BASE_URL=https://algodev.in:62040/v1/

# Base URL used to resolve legacy relative image paths (non-CDN images).
# Local development:
REACT_APP_IMAGE_BASE_URL=http://localhost:3301/
# Production (uncomment):
# REACT_APP_IMAGE_BASE_URL=https://algodev.in:62040/

# API request encryption key (must match backend AES-GCM key).
REACT_APP_API_KEY=

# -----------------------------------------------------------------------------
# Media delivery
# Images are uploaded to server storage via the backend proxy endpoint
# (POST /common/media/upload). The backend returns the public server URL.
# Bunny CDN is intentionally disabled by default and remains a future opt-in.
# Storage credentials, if CDN is re-enabled, live ONLY on the backend.
# -----------------------------------------------------------------------------

# Server media is the default. Keep CDN disabled unless the API is explicitly
# switched back to Bunny delivery.
REACT_APP_USE_BUNNY_CDN=false
# Optional pull-zone base URL for future CDN mode.
# REACT_APP_BUNNY_CDN_PULL_ZONE=https://pgti.b-cdn.net

# Folder convention under server media storage:
#   banners/              - CMS banner images
#   categories/           - category thumbnail images
#   sub-categories/       - sub-category thumbnail images
#   products/             - product gallery images
#   articles/             - article cover / inline images
#   events/               - event images
#   users/                - user profile / avatar images
#   accounts/             - admin account avatars
#   cms/about-us/         - About Us page assets
#   cms/tour-partners/    - Tour Partners page assets
#   cms/highlight-videos/ - Highlight Video thumbnails
#   common/               - general / clipart gallery
